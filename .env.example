# Server Configuration
PORT=3000
NODE_ENV=development

# Database connection URL (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/yikeyue

# Redis connection URL
REDIS_URL=redis://localhost:6379

# JWT HS256 sign/verification secret (minimum 32 characters)
JWT_SECRET=test-jwt-secret-key-at-least-32-chars-long

# WeChat Integration Credentials
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=abcdef0123456789abcdef0123456789
WECHAT_MCH_ID=1234567890
WECHAT_API_V3_KEY=abcdef0123456789abcdef0123456789
WECHAT_CERT_SERIAL_NO=1234567890ABCDEF1234567890ABCDEF12345678
WECHAT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
